{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "plannotator",
            "timeout": 1800
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_EVENT=PreToolUse node ~/.claude/hooks/main-branch-guard.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/bryanarendt/dotfiles/agents/.agents/skills/turbocommit/cli.js\" hook pre-tool-use"
          }
        ],
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash|mcp__.*"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_EVENT=PostToolUse node ~/.claude/hooks/main-branch-guard.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/generate-session-url.js"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/anders-session-end.js"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/extract-assistant-urls.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/bryanarendt/dotfiles/agents/.agents/skills/turbocommit/cli.js\" hook stop"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/anders-session-start.js"
          },
          {
            "type": "command",
            "command": "rm -f /tmp/claude-main-guard-*"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/bryanarendt/dotfiles/agents/.agents/skills/turbocommit/cli.js\" hook session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/bryanarendt/dotfiles/agents/.agents/skills/turbocommit/cli.js\" hook session-end"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "vtsls@claude-code-lsps": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./plans/",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
